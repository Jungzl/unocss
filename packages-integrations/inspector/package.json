{
  "name": "@unocss/inspector",
  "type": "module",
  "version": "66.6.5",
  "description": "The inspector UI for UnoCSS",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://unocss.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unocss/unocss.git",
    "directory": "packages-integrations/inspector"
  },
  "bugs": {
    "url": "https://github.com/unocss/unocss/issues"
  },
  "keywords": [
    "unocss",
    "inspector",
    "debugger"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "build-post": "vite build",
    "dev": "tsdown --config-loader unrun --watch",
    "update-post": "vite build"
  },
  "dependencies": {
    "@codemirror/lang-css": "catalog:codemirror",
    "@codemirror/lang-html": "catalog:codemirror",
    "@codemirror/lang-javascript": "catalog:codemirror",
    "@codemirror/lang-xml": "catalog:codemirror",
    "@lezer/highlight": "catalog:codemirror",
    "@unocss/core": "workspace:*",
    "@unocss/preset-attributify": "workspace:*",
    "@unocss/reset": "workspace:*",
    "@unocss/rule-utils": "workspace:*",
    "codemirror": "catalog:codemirror",
    "colorette": "catalog:utils",
    "gzip-size": "catalog:build",
    "sirv": "catalog:utils"
  },
  "devDependencies": {
    "@vitejs/devtools-kit": "catalog:types",
    "vite": "catalog:vite",
    "vue-flow-layout": "catalog:vue"
  }
}
